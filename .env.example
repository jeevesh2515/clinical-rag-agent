# ── Cohere (used for embedding + reranking — required for best retrieval) ──────
COHERE_API_KEY=

# ── OpenRouter (free tier LLMs — required for AI generation out of the box) ───
# Get your free key at: https://openrouter.ai/keys
# Verified free models (Jul 2026): Nemotron Nano 30B, Nemotron Ultra 550B, Gemma 4 26B, Llama 3.3 70B
OPENROUTER_API_KEY=

# ── Premium LLM providers (optional — add key to unlock in model picker) ───────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ── Web search (optional) ──────────────────────────────────────────────────────
TAVILY_API_KEY=

# ── App config ─────────────────────────────────────────────────────────────────
# SQLite (local dev):
#   DATABASE_URL=sqlite:///./clinical_demo.db
# PostgreSQL + pgvector (free production with Neon or Supabase):
#   DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech:5432/neondb?sslmode=require
DATABASE_URL=sqlite:///./clinical_demo.db
# 'auto' = use pgvector when DATABASE_URL starts with postgresql://, else in-memory
VECTOR_STORE=auto
APP_ENV=local
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,https://clinical-workflows.vercel.app
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-in-production-use-a-strong-random-key

# ── LangSmith Observability (optional) ─────────────────────────────────────────
# Both LANGSMITH_ and LANGCHAIN_ prefixes are supported and mapped automatically.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=clinical-rag-agent
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Alternate standard LangChain keys:
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=clinical-rag-agent
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
