import React, { useState, useEffect, useCallback } from 'react'
import { Menu, X, LogOut, Settings, Plus, MessageSquare, Send, ChevronDown, User as UserIcon, Activity, Shield, BarChart3, FileText, Scale } from 'lucide-react'
import { useAuth } from './hooks/useAuth'
import { useChat } from './hooks/useChat'
import { useApi } from './hooks/useApi'
import type { ChatMessage, ConversationSummary, Conversation } from './types/chat'
import { cn } from './lib/utils'

export const App: React.FC = () => {
  const { user, token, isAuthenticated, login, register, logout, isLoading: authLoading } = useAuth()
  const { 
    createConversation, 
    listConversations, 
    getConversation, 
    addMessage, 
    deleteConversation,
    isLoading: chatLoading 
  } = useChat(token)
  
  const [conversations, setConversations] = useState<ConversationSummary[]>([])
  const [currentConversation, setCurrentConversation] = useState<Conversation | null>(null)
  const [messages, setMessages] = useState<ChatMessage[]>([])
  const [inputValue, setInputValue] = useState('')
  const [sidebarOpen, setSidebarOpen] = useState(true)
  const [rightPanelTab, setRightPanelTab] = useState<'citations' | 'tools' | 'safety' | 'knowledge'>('citations')
  const [authMode, setAuthMode] = useState<'login' | 'signup'>('login')
  const [mode, setMode] = useState<'patient' | 'clinician'>('patient')

  // Load conversations
  const refreshConversations = useCallback(async () => {
    if (isAuthenticated) {
      const data = await listConversations()
      setConversations(data)
    }
  }, [isAuthenticated, listConversations])

  useEffect(() => {
    refreshConversations()
  }, [refreshConversations])

  const handleNewConversation = async () => {
    const newConv = await createConversation()
    if (newConv) {
      setCurrentConversation(newConv)
      setMessages([])
      refreshConversations()
    }
  }

  const handleSelectConversation = async (id: string) => {
    const conv = await getConversation(id)
    if (conv) {
      setCurrentConversation(conv)
      setMessages(conv.messages)
    }
  }

  const handleSendMessage = async () => {
    if (!inputValue.trim() || !currentConversation) return

    const question = inputValue
    setInputValue('')
    
    // Optimistic update
    const tempId = `temp-${Date.now()}`
    const userMsg: ChatMessage = {
      id: tempId,
      user_id: user?.id || '',
      conversation_id: currentConversation.id,
      role: 'user',
      content: question,
      timestamp: new Date().toISOString()
    }
    setMessages(prev => [...prev, userMsg])

    const response = await addMessage(currentConversation.id, question, mode)
    if (response) {
      setMessages(prev => [...prev.filter(m => m.id !== tempId), userMsg, response])
    }
  }

  const handleDeleteConversation = async (e: React.MouseEvent, id: string) => {
    e.stopPropagation()
    if (await deleteConversation(id)) {
      if (currentConversation?.id === id) {
        setCurrentConversation(null)
        setMessages([])
      }
      refreshConversations()
    }
  }

  if (!isAuthenticated) {
    return (
      <AuthModal 
        mode={authMode} 
        setMode={setAuthMode} 
        onLogin={login} 
        onRegister={register} 
        isLoading={authLoading} 
      />
    )
  }

  return (
    <div className="flex h-screen bg-white font-sans text-gray-900">
      {/* Left Panel - Sidebar */}
      <div className={cn(
        "bg-gray-50 border-r border-gray-200 flex flex-col transition-all duration-300",
        sidebarOpen ? "w-72" : "w-16"
      )}>
        <div className="p-4 border-b border-gray-200 flex items-center gap-3 overflow-hidden">
          <div className="w-8 h-8 rounded-lg bg-blue-600 flex-shrink-0 flex items-center justify-center text-white font-bold shadow-sm">
            CW
          </div>
          {sidebarOpen && <span className="font-bold text-lg whitespace-nowrap">Clinical Workflows</span>}
        </div>

        <div className="p-3">
          <button
            onClick={handleNewConversation}
            className="w-full flex items-center justify-center gap-2 px-4 py-2.5 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-all shadow-sm font-medium"
          >
            <Plus size={18} />
            {sidebarOpen && <span>New Chat</span>}
          </button>
        </div>

        <div className="flex-1 overflow-y-auto px-2 py-2 space-y-1">
          {conversations.map((conv) => (
            <div
              key={conv.id}
              onClick={() => handleSelectConversation(conv.id)}
              className={cn(
                "group relative flex items-center gap-3 px-3 py-2.5 rounded-lg cursor-pointer transition-all",
                currentConversation?.id === conv.id
                  ? "bg-blue-50 text-blue-700 ring-1 ring-blue-100"
                  : "text-gray-600 hover:bg-gray-100"
              )}
            >
              <MessageSquare size={18} className="flex-shrink-0" />
              {sidebarOpen && (
                <div className="flex-1 min-w-0">
                  <div className="text-sm font-medium truncate">{conv.title}</div>
                  <div className="text-[10px] opacity-60 uppercase tracking-wider">
                    {new Date(conv.updated_at).toLocaleDateString()}
                  </div>
                </div>
              )}
              {sidebarOpen && (
                <button
                  onClick={(e) => handleDeleteConversation(e, conv.id)}
                  className="opacity-0 group-hover:opacity-100 p-1 hover:bg-gray-200 rounded text-gray-400 hover:text-red-500 transition-all"
                >
                  <X size={14} />
                </button>
              )}
            </div>
          ))}
        </div>

        <div className="p-4 border-t border-gray-200 bg-gray-50/50">
          <div className="flex items-center gap-3">
            <div className="w-9 h-9 rounded-full bg-blue-100 text-blue-700 flex items-center justify-center font-bold ring-2 ring-white">
              {user?.username[0].toUpperCase()}
            </div>
            {sidebarOpen && (
              <div className="flex-1 min-w-0">
                <div className="text-sm font-semibold truncate">{user?.username}</div>
                <div className="text-[10px] text-gray-500 font-medium uppercase">{user?.roles[0]}</div>
              </div>
            )}
            <button
              onClick={logout}
              className="p-2 hover:bg-gray-200 rounded-lg transition-colors text-gray-500 hover:text-red-500"
              title="Logout"
            >
              <LogOut size={18} />
            </button>
          </div>
        </div>

        <button
          onClick={() => setSidebarOpen(!sidebarOpen)}
          className="p-3 border-t border-gray-200 hover:bg-gray-100 transition-colors flex justify-center text-gray-400"
        >
          {sidebarOpen ? <Menu size={18} /> : <Plus size={18} className="rotate-45" />}
        </button>
      </div>

      {/* Center Panel - Chat */}
      <div className="flex-1 flex flex-col min-w-0">
        <header className="h-16 border-b border-gray-200 flex items-center justify-between px-6 bg-white/80 backdrop-blur-md sticky top-0 z-10">
          <div className="flex items-center gap-4">
            <h2 className="text-lg font-bold text-gray-900 truncate max-w-md">
              {currentConversation?.title || 'Welcome to Clinical Workflows'}
            </h2>
          </div>
          <div className="flex items-center gap-3">
            <div className="flex bg-gray-100 p-1 rounded-lg ring-1 ring-gray-200">
              <button
                onClick={() => setMode('patient')}
                className={cn(
                  "px-3 py-1.5 text-xs font-semibold rounded-md transition-all",
                  mode === 'patient' ? "bg-white text-blue-600 shadow-sm" : "text-gray-500 hover:text-gray-700"
                )}
              >
                Patient
              </button>
              <button
                onClick={() => setMode('clinician')}
                className={cn(
                  "px-3 py-1.5 text-xs font-semibold rounded-md transition-all",
                  mode === 'clinician' ? "bg-white text-blue-600 shadow-sm" : "text-gray-500 hover:text-gray-700"
                )}
              >
                Clinician
              </button>
            </div>
            <button className="p-2 text-gray-400 hover:text-gray-600 transition-colors">
              <Settings size={20} />
            </button>
          </div>
        </header>

        <div className="flex-1 overflow-y-auto p-6 space-y-6 scroll-smooth">
          {messages.length === 0 ? (
            <div className="h-full flex flex-col items-center justify-center text-center max-w-md mx-auto">
              <div className="w-16 h-16 bg-blue-50 rounded-2xl flex items-center justify-center text-blue-600 mb-6 ring-1 ring-blue-100">
                <Activity size={32} />
              </div>
              <h1 className="text-2xl font-bold text-gray-900 mb-2">How can I help you today?</h1>
              <p className="text-gray-500 text-sm leading-relaxed">
                Select a conversation from the history or start a new one to begin evidence-based clinical workflow planning.
              </p>
              <div className="grid grid-cols-2 gap-3 mt-8 w-full">
                {['BP Target for CKD', 'Hypertension Stage 1', 'MAP Calculation', 'NICE Guidelines'].map(q => (
                  <button 
                    key={q}
                    onClick={() => setInputValue(q)}
                    className="p-3 text-xs font-medium text-gray-600 bg-gray-50 border border-gray-200 rounded-xl hover:bg-blue-50 hover:border-blue-200 hover:text-blue-600 transition-all text-left"
                  >
                    {q}
                  </button>
                ))}
              </div>
            </div>
          ) : (
            messages.map((msg) => (
              <div
                key={msg.id}
                className={cn(
                  "flex w-full",
                  msg.role === 'user' ? "justify-end" : "justify-start"
                )}
              >
                <div className={cn(
                  "max-w-[85%] px-5 py-4 rounded-2xl shadow-sm leading-relaxed",
                  msg.role === 'user'
                    ? "bg-blue-600 text-white rounded-tr-none"
                    : "bg-gray-50 text-gray-800 border border-gray-200 rounded-tl-none"
                )}>
                  <div className="text-sm whitespace-pre-wrap">{msg.content}</div>
                  <div className={cn(
                    "text-[10px] mt-2 font-medium opacity-50",
                    msg.role === 'user' ? "text-right" : "text-left"
                  )}>
                    {new Date(msg.timestamp).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}
                  </div>
                </div>
              </div>
            ))
          )}
          {(chatLoading) && (
            <div className="flex justify-start">
              <div className="bg-gray-50 border border-gray-200 px-5 py-4 rounded-2xl rounded-tl-none">
                <div className="flex gap-1.5">
                  <div className="w-1.5 h-1.5 bg-blue-400 rounded-full animate-bounce"></div>
                  <div className="w-1.5 h-1.5 bg-blue-400 rounded-full animate-bounce delay-75"></div>
                  <div className="w-1.5 h-1.5 bg-blue-400 rounded-full animate-bounce delay-150"></div>
                </div>
              </div>
            </div>
          )}
        </div>

        <div className="p-6 bg-white">
          <div className="max-w-4xl mx-auto relative group">
            <textarea
              value={inputValue}
              onChange={(e) => setInputValue(e.target.value)}
              onKeyDown={(e) => {
                if (e.key === 'Enter' && !e.shiftKey) {
                  e.preventDefault()
                  handleSendMessage()
                }
              }}
              placeholder="Type your clinical question here..."
              className="w-full pl-5 pr-14 py-4 bg-gray-50 border border-gray-200 rounded-2xl focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all resize-none shadow-sm text-sm"
              rows={1}
              disabled={chatLoading || !currentConversation}
            />
            <button
              onClick={handleSendMessage}
              disabled={chatLoading || !inputValue.trim() || !currentConversation}
              className="absolute right-3 top-1/2 -translate-y-1/2 p-2 bg-blue-600 text-white rounded-xl hover:bg-blue-700 disabled:bg-gray-200 disabled:text-gray-400 transition-all shadow-md"
            >
              <Send size={18} />
            </button>
          </div>
          <div className="mt-3 text-center">
            <p className="text-[10px] text-gray-400 font-medium">
              Clinical Workflows AI can make mistakes. Verify critical information with official guidelines.
            </p>
          </div>
        </div>
      </div>

      {/* Right Panel - Context */}
      <div className="w-80 bg-gray-50 border-l border-gray-200 flex flex-col overflow-hidden">
        <div className="flex border-b border-gray-200 bg-white">
          {(['citations', 'tools', 'safety', 'knowledge'] as const).map((tab) => (
            <button
              key={tab}
              onClick={() => setRightPanelTab(tab)}
              className={cn(
                "flex-1 px-2 py-3.5 text-[10px] font-bold uppercase tracking-widest transition-all relative",
                rightPanelTab === tab ? "text-blue-600" : "text-gray-400 hover:text-gray-600"
              )}
            >
              {tab}
              {rightPanelTab === tab && <div className="absolute bottom-0 left-0 right-0 h-0.5 bg-blue-600" />}
            </button>
          ))}
        </div>

        <div className="flex-1 overflow-y-auto p-4 space-y-4">
          {rightPanelTab === 'citations' && (
            <div className="space-y-3">
              <h3 className="text-xs font-bold text-gray-400 uppercase tracking-wider mb-2">Evidence Sources</h3>
              {messages.length > 0 && messages[messages.length - 1].citations?.map((c, i) => (
                <div key={i} className="p-4 bg-white rounded-xl border border-gray-200 shadow-sm hover:border-blue-200 transition-colors">
                  <div className="flex items-start gap-2 mb-2">
                    <FileText size={14} className="text-blue-500 mt-0.5" />
                    <span className="text-xs font-bold text-gray-900 leading-tight">{c.title}</span>
                  </div>
                  <div className="text-[10px] font-bold text-blue-600 mb-2">PAGE {c.page}</div>
                  <p className="text-[11px] text-gray-600 leading-relaxed italic">"{c.quote}"</p>
                </div>
              ))}
              {(!messages.length || !messages[messages.length - 1].citations?.length) && (
                <div className="text-center py-12">
                  <FileText size={32} className="text-gray-200 mx-auto mb-3" />
                  <p className="text-xs text-gray-400 font-medium">No citations found for this message</p>
                </div>
              )}
            </div>
          )}

          {rightPanelTab === 'tools' && (
            <div className="space-y-3">
              <h3 className="text-xs font-bold text-gray-400 uppercase tracking-wider mb-2">System Execution</h3>
              {messages.length > 0 && messages[messages.length - 1].tool_trace?.map((t, i) => (
                <div key={i} className="p-4 bg-white rounded-xl border border-gray-200 shadow-sm">
                  <div className="flex items-center gap-2 mb-3">
                    <Shield size={14} className="text-green-500" />
                    <span className="text-xs font-bold text-gray-900">{t.name}</span>
                  </div>
                  <div className="space-y-2">
                    <div className="text-[10px]">
                      <span className="text-gray-400 font-bold uppercase block mb-1">Input</span>
                      <pre className="p-2 bg-gray-50 rounded-lg text-gray-600 overflow-x-auto">{JSON.stringify(t.inputs, null, 2)}</pre>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          )}
          
          {/* Add Safety and Knowledge content similarly */}
        </div>
      </div>
    </div>
  )
}

const AuthModal: React.FC<{
  mode: 'login' | 'signup',
  setMode: (m: 'login' | 'signup') => void,
  onLogin: (u: string, p: string) => Promise<void>,
  onRegister: (u: string, e: string, p: string) => Promise<void>,
  isLoading: boolean
}> = ({ mode, setMode, onLogin, onRegister, isLoading }) => {
  const [username, setUsername] = useState('')
  const [email, setEmail] = useState('')
  const [password, setPassword] = useState('')

  const handleSubmit = (e: React.FormEvent) => {
    e.preventDefault()
    if (mode === 'login') onLogin(username, password)
    else onRegister(username, email, password)
  }

  return (
    <div className="min-h-screen bg-gray-50 flex items-center justify-center p-6">
      <div className="w-full max-w-md bg-white rounded-3xl shadow-xl shadow-blue-500/5 p-8 border border-gray-100">
        <div className="text-center mb-10">
          <div className="w-16 h-16 bg-blue-600 rounded-2xl flex items-center justify-center text-white font-bold text-2xl mx-auto mb-6 shadow-lg shadow-blue-600/20">
            CW
          </div>
          <h1 className="text-3xl font-black text-gray-900 tracking-tight">Clinical Workflows</h1>
          <p className="text-gray-500 mt-2 font-medium">Evidence-Based Care Planning System</p>
        </div>

        <form onSubmit={handleSubmit} className="space-y-5">
          <div>
            <label className="block text-xs font-bold text-gray-400 uppercase tracking-widest mb-2 ml-1">Username</label>
            <input
              type="text"
              required
              value={username}
              onChange={e => setUsername(e.target.value)}
              className="w-full px-5 py-3.5 bg-gray-50 border border-gray-200 rounded-2xl focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all outline-none text-sm font-medium"
              placeholder="Enter your username"
            />
          </div>

          {mode === 'signup' && (
            <div>
              <label className="block text-xs font-bold text-gray-400 uppercase tracking-widest mb-2 ml-1">Email Address</label>
              <input
                type="email"
                required
                value={email}
                onChange={e => setEmail(e.target.value)}
                className="w-full px-5 py-3.5 bg-gray-50 border border-gray-200 rounded-2xl focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all outline-none text-sm font-medium"
                placeholder="name@example.com"
              />
            </div>
          )}

          <div>
            <label className="block text-xs font-bold text-gray-400 uppercase tracking-widest mb-2 ml-1">Password</label>
            <input
              type="password"
              required
              value={password}
              onChange={e => setPassword(e.target.value)}
              className="w-full px-5 py-3.5 bg-gray-50 border border-gray-200 rounded-2xl focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all outline-none text-sm font-medium"
              placeholder="••••••••"
            />
          </div>

          <button
            type="submit"
            disabled={isLoading}
            className="w-full py-4 bg-blue-600 text-white rounded-2xl font-bold text-sm shadow-lg shadow-blue-600/20 hover:bg-blue-700 active:scale-[0.98] transition-all disabled:bg-gray-200 disabled:shadow-none mt-4"
          >
            {isLoading ? 'Processing...' : (mode === 'login' ? 'Sign In' : 'Create Account')}
          </button>
        </form>

        <div className="mt-8 text-center">
          <button
            onClick={() => setMode(mode === 'login' ? 'signup' : 'login')}
            className="text-sm font-bold text-blue-600 hover:text-blue-700 transition-colors"
          >
            {mode === 'login' ? "Don't have an account? Sign Up" : "Already have an account? Sign In"}
          </button>
        </div>
      </div>
    </div>
  )
}
